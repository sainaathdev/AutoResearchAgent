# ====================================================
# Autonomous Research Agent - Environment Variables
# ====================================================

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.1

# Semantic Scholar API (optional, get free key at https://www.semanticscholar.org/product/api)
SEMANTIC_SCHOLAR_API_KEY=

# ChromaDB Storage
CHROMA_DB_PATH=./data/chroma_db

# Research Output Directory
OUTPUT_DIR=./data/reports

# PDF Cache Directory
PDF_CACHE_DIR=./data/pdf_cache

# Max papers to fetch per search
MAX_PAPERS_PER_SEARCH=20
MAX_PAPERS_TO_PROCESS=10

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Relevance threshold (0-1)
RELEVANCE_THRESHOLD=0.6
